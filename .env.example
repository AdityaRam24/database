# Example environment variables for DB-Lighthouse AI

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/your_db
SHADOW_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/shadow_db

# AI (Jan)
JAN_API_URL=http://localhost:1337/v1
JAN_MODEL_NAME=mistral-ins-7b-q4

# Optional: OpenAI API key if using OpenAI backend
OPENAI_API_KEY=

# Local LLM (if using LOCAL_FILE mode)
USE_LOCAL_AI=false
LOCAL_MODEL_PATH=models/Jan-v3-4b-base-instruct-Q4_K_XL.gguf
AI_MODE=JAN

# Firebase (optional)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
